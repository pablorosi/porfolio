@media (min-width: 768px) {
  .top-bar {

    position: sticky;
    top: 0;
    
    padding-top: 0; 
  }
}

  .moon { display: none; }
  .sun { display: block; }
  

  :global([data-theme='light']) .sun { display: none !important; }
  :global([data-theme='light']) .moon { display: block !important; }
</style>
<script is:inline>

  // 1. Determine the initial theme (Local storage or system preference)
  const getTheme = () => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  };

  // 2. Function to inject the state into the DOM and the Hardware Status Bar
  const setTheme = (theme) => {
    const metaThemeColor = document.querySelector('meta[name="theme-color"]');
    
    if (theme === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
      // Tell iOS/Android to paint the notch area light
      if (metaThemeColor) metaThemeColor.setAttribute('content', '#E5EDF7'); 
    } else {
      document.documentElement.removeAttribute('data-theme'); // Your CSS defaults to dark
      // Tell iOS/Android to paint the notch area dark
      if (metaThemeColor) metaThemeColor.setAttribute('content', '#162335'); 
    }
    window.localStorage.setItem('theme', theme);
  };

  // 3. Initialize the theme on page load
  let currentTheme = getTheme();
  setTheme(currentTheme);

  // 4. Attach the event listener to your toggle button
  const themeToggleButton = document.getElementById('theme-toggle');
  if (themeToggleButton) {
    themeToggleButton.addEventListener('click', () => {
      currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
      setTheme(currentTheme);
    });
  }
</script>