<style>
.top-bar {
    width: 100%; 
    min-height: 55px; 
    height: auto;
    

    position: relative;
    z-index: 1000;
    display: flex;
    align-items: center;


    background: rgba(22, 35, 53, 0.7); 
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);

    
    padding-top: env(safe-area-inset-top, 0px);
  }

  .bar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.8rem 1.5rem 0.8rem;
  }


  .logo {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: #FFFFFF;
    display: flex;
    gap: 0.2rem;
  }



  :global([data-theme='light']) .top-bar {
    background: rgba(229, 237, 247, 0.7); 
  }


  :global([data-theme='light']) .logo {
    color: #162335; 
  }

 
  :global([data-theme='light']) .nav-links a {
    color: #162335;
  }

  .bracket {
    color: var(--color-accent);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 1.2rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--color-gray-3);
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(var(--color-accent-rgb), 0.1);
  }

  .nav-links .nav-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    border-radius: 6px;
    line-height: 1;
  }

  .nav-links .nav-icon svg {
    display: block;
  }

  .theme-toggle {
    background: none;
    border: 1px solid var(--color-gray-5);
    border-radius: 6px;
    cursor: pointer;
    padding: 0.35rem;
    color: var(--color-gray-3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(var(--color-accent-rgb), 0.1);
  }

  :root[data-theme='light'] .sun { display: none; }
  :root[data-theme='dark'] .moon { display: none; }
  
  @media (max-width: 600px) {
    .nav-links { display: none; } 
  }

  @media (max-width: 720px) {
